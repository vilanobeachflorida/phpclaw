{
    "name": "phpclaw/phpclaw",
    "description": "Terminal-first multi-model AI agent shell for PHP",
    "license": "MIT",
    "type": "project",
    "homepage": "https://github.com/sergiozlobin/phpclaw",
    "keywords": ["ai", "agent", "cli", "llm", "ollama", "chatgpt", "claude", "terminal"],
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "codeigniter4/framework": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.2"
    },
    "suggest": {
        "ext-pcntl": "Required for signal handling (graceful shutdown)",
        "ext-readline": "Improves chat input with history and line editing",
        "ext-posix": "Required for TTY detection and terminal features"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "setup": "php spark agent:setup",
        "chat": "php spark agent:chat",
        "serve": "php spark agent:serve"
    },
    "minimum-stability": "stable"
}
