{
    "tools": {
        "file_read": {
            "enabled": true,
            "description": "Read file contents",
            "timeout": 10
        },
        "file_write": {
            "enabled": true,
            "description": "Write content to file",
            "timeout": 10
        },
        "file_append": {
            "enabled": true,
            "description": "Append content to file",
            "timeout": 10
        },
        "dir_list": {
            "enabled": true,
            "description": "List directory contents",
            "timeout": 10
        },
        "mkdir": {
            "enabled": true,
            "description": "Create directory",
            "timeout": 10
        },
        "move_file": {
            "enabled": true,
            "description": "Move or rename file",
            "timeout": 10
        },
        "delete_file": {
            "enabled": true,
            "description": "Delete a file",
            "timeout": 10
        },
        "grep_search": {
            "enabled": true,
            "description": "Search file contents with patterns",
            "timeout": 30
        },
        "http_get": {
            "enabled": true,
            "description": "Make HTTP GET request",
            "timeout": 30
        },
        "browser_fetch": {
            "enabled": true,
            "description": "Fetch web page content",
            "timeout": 30
        },
        "browser_text": {
            "enabled": true,
            "description": "Extract text from web page",
            "timeout": 30
        },
        "shell_exec": {
            "enabled": true,
            "description": "Execute shell command",
            "timeout": 60,
            "allowed_commands": []
        },
        "system_info": {
            "enabled": true,
            "description": "Get system information",
            "timeout": 10
        },
        "git_ops": {
            "enabled": true,
            "description": "Structured git operations with parsed output",
            "timeout": 30,
            "allowed_operations": []
        },
        "code_patch": {
            "enabled": true,
            "description": "Surgical code editing via exact string replacement",
            "timeout": 10
        },
        "db_query": {
            "enabled": true,
            "description": "Execute SQL queries against configured databases",
            "timeout": 30,
            "max_rows": 1000,
            "read_only": false,
            "connections": {
                "default": {
                    "driver": "sqlite",
                    "database": "writable/agent/data/agent.db"
                }
            }
        },
        "image_generate": {
            "enabled": true,
            "description": "Generate images from text prompts",
            "timeout": 120,
            "provider": "openai",
            "output_dir": "writable/agent/generated/images"
        },
        "cron_schedule": {
            "enabled": true,
            "description": "Create and manage scheduled recurring tasks",
            "timeout": 10,
            "schedule_dir": "writable/agent/schedules",
            "max_schedules": 50
        },
        "diff_review": {
            "enabled": true,
            "description": "Analyze code diffs with structured per-hunk output",
            "timeout": 30
        },
        "http_request": {
            "enabled": true,
            "description": "Full HTTP client with all methods and body support",
            "timeout": 30,
            "max_body_size": 10485760,
            "blocked_hosts": []
        },
        "archive_extract": {
            "enabled": true,
            "description": "Create and extract archive files",
            "timeout": 60,
            "max_extract_size": 104857600
        },
        "process_manager": {
            "enabled": true,
            "description": "Start, monitor, and stop background processes",
            "timeout": 10,
            "state_dir": "writable/agent/processes",
            "max_processes": 20,
            "allowed_commands": []
        },
        "notification_send": {
            "enabled": true,
            "description": "Send notifications via multiple channels",
            "timeout": 15,
            "channels": {
                "desktop": {
                    "enabled": true
                },
                "slack": {
                    "enabled": false
                },
                "discord": {
                    "enabled": false
                },
                "telegram": {
                    "enabled": false
                },
                "email": {
                    "enabled": false
                }
            }
        },
        "exec_target": {
            "enabled": true,
            "description": "Manage execution targets (local, SSH, Docker, K8s)",
            "timeout": 30,
            "active_target": "local"
        },
        "project_detect": {
            "enabled": true,
            "description": "Auto-detect project stack and toolchain",
            "timeout": 15
        },
        "test_runner": {
            "enabled": true,
            "description": "Universal test runner with structured results",
            "timeout": 120,
            "junit_output": true
        },
        "lint_check": {
            "enabled": true,
            "description": "Universal linter/formatter with structured diagnostics",
            "timeout": 60
        },
        "code_symbols": {
            "enabled": true,
            "description": "Language-agnostic code intelligence via ctags",
            "timeout": 30,
            "tags_file": ".tags",
            "use_ctags": true,
            "max_results": 100
        },
        "task_planner": {
            "enabled": true,
            "description": "Multi-step task planning with persistent checkpoints",
            "timeout": 10,
            "plans_dir": "writable/agent/plans",
            "max_plans": 50
        },
        "build_runner": {
            "enabled": true,
            "description": "Universal build system and dependency management",
            "timeout": 120
        },
        "error_parser": {
            "enabled": true,
            "description": "Parse errors from any language into structured output",
            "timeout": 10,
            "max_errors": 100
        },
        "context_manager": {
            "enabled": true,
            "description": "Context compression, stashing, and recall",
            "timeout": 15,
            "stash_dir": "writable/agent/context_stash",
            "max_stashes": 20
        }
    }
}
