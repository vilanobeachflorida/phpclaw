{
    "tools": {
        "file_read": {
            "enabled": true,
            "description": "Read file contents",
            "timeout": 10
        },
        "file_write": {
            "enabled": true,
            "description": "Write content to file",
            "timeout": 10
        },
        "file_append": {
            "enabled": true,
            "description": "Append content to file",
            "timeout": 10
        },
        "dir_list": {
            "enabled": true,
            "description": "List directory contents",
            "timeout": 10
        },
        "mkdir": {
            "enabled": true,
            "description": "Create directory",
            "timeout": 10
        },
        "move_file": {
            "enabled": true,
            "description": "Move or rename file",
            "timeout": 10
        },
        "delete_file": {
            "enabled": true,
            "description": "Delete a file",
            "timeout": 10
        },
        "grep_search": {
            "enabled": true,
            "description": "Search file contents with patterns",
            "timeout": 30
        },
        "http_get": {
            "enabled": true,
            "description": "Make HTTP GET request",
            "timeout": 30
        },
        "browser_fetch": {
            "enabled": true,
            "description": "Fetch web page content",
            "timeout": 30
        },
        "browser_text": {
            "enabled": true,
            "description": "Extract text from web page",
            "timeout": 30
        },
        "shell_exec": {
            "enabled": true,
            "description": "Execute shell command",
            "timeout": 60,
            "allowed_commands": []
        },
        "system_info": {
            "enabled": true,
            "description": "Get system information",
            "timeout": 10
        },
        "git_ops": {
            "enabled": true,
            "description": "Structured git operations with parsed output",
            "timeout": 30,
            "allowed_operations": []
        },
        "code_patch": {
            "enabled": true,
            "description": "Surgical code editing via exact string replacement",
            "timeout": 10
        },
        "db_query": {
            "enabled": true,
            "description": "Execute SQL queries against configured databases",
            "timeout": 30,
            "max_rows": 1000,
            "read_only": false,
            "connections": {
                "default": {
                    "driver": "sqlite",
                    "database": "writable/agent/data/agent.db"
                }
            }
        },
        "image_generate": {
            "enabled": true,
            "description": "Generate images from text prompts",
            "timeout": 120,
            "provider": "openai",
            "output_dir": "writable/agent/generated/images",
            "openai": {
                "api_key_env": "OPENAI_API_KEY",
                "model": "dall-e-3",
                "size": "1024x1024",
                "quality": "standard"
            },
            "stable_diffusion": {
                "base_url": "http://localhost:7860",
                "steps": 30,
                "width": 1024,
                "height": 1024
            },
            "comfyui": {
                "base_url": "http://localhost:8188"
            }
        },
        "cron_schedule": {
            "enabled": true,
            "description": "Create and manage scheduled recurring tasks",
            "timeout": 10,
            "schedule_dir": "writable/agent/schedules",
            "max_schedules": 50
        },
        "diff_review": {
            "enabled": true,
            "description": "Analyze code diffs with structured per-hunk output",
            "timeout": 30
        },
        "http_request": {
            "enabled": true,
            "description": "Full HTTP client with all methods, headers, and body support",
            "timeout": 30,
            "max_body_size": 10485760,
            "blocked_hosts": []
        },
        "archive_extract": {
            "enabled": true,
            "description": "Create and extract archive files (ZIP, tar.gz, tar.bz2)",
            "timeout": 60,
            "max_extract_size": 104857600
        },
        "process_manager": {
            "enabled": true,
            "description": "Start, monitor, and stop background processes",
            "timeout": 10,
            "state_dir": "writable/agent/processes",
            "max_processes": 20,
            "allowed_commands": []
        },
        "notification_send": {
            "enabled": true,
            "description": "Send notifications via email, Slack, Discord, Telegram, or desktop",
            "timeout": 15,
            "channels": {
                "desktop": { "enabled": true },
                "slack": { "enabled": false, "webhook_url_env": "SLACK_WEBHOOK_URL" },
                "discord": { "enabled": false, "webhook_url_env": "DISCORD_WEBHOOK_URL" },
                "telegram": { "enabled": false, "bot_token_env": "TELEGRAM_BOT_TOKEN", "chat_id_env": "TELEGRAM_CHAT_ID" },
                "email": { "enabled": false, "smtp_host": "localhost", "smtp_port": 25, "from": "phpclaw@localhost" }
            }
        }
    }
}
